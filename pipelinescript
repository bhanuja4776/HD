pipeline {
    agent any

    environment {
        SONAR_HOST_URL = 'https://sonarcloud.io'
        SONAR_PROJECT_KEY = 'bhanuja4776_HD'
        SONAR_ORGANIZATION = 'bhanuja4776'
        SONAR_TOKEN = '578955d67936c804bd61112ba8952e050c5f1df0'
    }

    stages {
        stage('Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/bhanuja4776/HD.git'
            }
        }

        stage('Setup') {
            steps {
                bat '''
                where sonar-scanner >nul 2>nul || npm install -g sonar-scanner
                cd server
                npm ci
                '''
            }
        }

        stage('Build') {
            steps {
                bat 'docker-compose build'
            }
        }

        stage('Test') {
            steps {
                bat '''
                cd server
                npm run test:coverage
                '''
            }
        }

        stage('Code Quality') {
            steps {
                bat '''
                cd server
                npm run test:coverage
                cd ..
                sonar-scanner ^
                  -Dsonar.host.url=%SONAR_HOST_URL% ^
                  -Dsonar.projectKey=%SONAR_PROJECT_KEY% ^
                  -Dsonar.organization=%SONAR_ORGANIZATION% ^
                  -Dsonar.sources=server ^
                  -Dsonar.tests=server/tests ^
                  -Dsonar.javascript.lcov.reportPaths=server/coverage/lcov.info ^
                  -Dsonar.login=%SONAR_TOKEN%
                '''
            }
        }

        stage('Security') {
    steps {
        bat '''
        cd server
        npm audit --audit-level=moderate || exit 0
        '''
    }
}

        stage('Deploy') {
            steps {
                bat 'docker-compose up -d'
            }
        }

        stage('Monitoring') {
    steps {
        bat '''
        echo Waiting for application to be ready...

        set RETRIES=10

        :loop
        curl -f http://localhost:3001/health >nul 2>nul
        if %ERRORLEVEL% EQU 0 (
            echo Application is healthy!
            exit /b 0
        )

        set /a RETRIES-=1
        if %RETRIES% LEQ 0 (
            echo Health check failed after retries!
            exit /b 1
        )

        echo Retrying...
        timeout /t 5 >nul
        goto loop
        '''
    }
}

       stage('Release') {
    steps {
        bat '''
        echo Creating release version...

        for /f %%i in ('powershell -NoProfile -Command "(Get-Date).ToString('yyyyMMddHHmmss')"') do set RELEASE_VERSION=v1.0.%%i

        echo Release version: %RELEASE_VERSION%

        echo Restarting containers for release...
        docker-compose restart

        echo Release completed successfully!
        '''
    }
}
    }
}
